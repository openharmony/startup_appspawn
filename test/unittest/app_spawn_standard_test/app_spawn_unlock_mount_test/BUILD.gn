import("//base/startup/appspawn/appspawn.gni")
import("//base/startup/appspawn/modules/sandbox/sandbox.gni")
import("//build/test.gni")

if (!defined(ohos_lite)) {
  # Hisysevent tests for unlock mount (ReportUnlockMountResult, ReportUnlockMountAppFail)
  # Uses mock_hisysevent to intercept HiSysEventWrite macro calls without
  # depending on the HiSysEvent daemon. The mock hisysevent.h is placed
  # first in include_dirs to shadow the real header from libhisysevent.
  ohos_unittest("AppSpawn_Unlock_Mount_Hisysevent_Test") {
    module_out_path = "appspawn/appspawn"
    if (appspawn_unittest_coverage) {
      cflags = [ "--coverage" ]
      ldflags = [ "--coverage" ]
      cflags_cc = [ "--coverage" ]
    }
    defines = [
      "APPSPAWN_TEST",
    ]

    include_dirs = [
      # Mock hisysevent.h must come first to shadow the real header
      "${appspawn_path}/test/mock/include/hisysevent_mock",
      "${appspawn_path}",
      "${appspawn_path}/common",
      "${appspawn_path}/standard",
      "${appspawn_path}/modules/sysevent",
      "${appspawn_path}/util/include",
    ]

    sources = [
      "${appspawn_path}/modules/sysevent/hisysevent_adapter.cpp",
      "app_spawn_unlock_mount_hisysevent_test.cpp",
    ]

    configs = [ "${appspawn_path}:appspawn_config" ]
    external_deps = [
      "cJSON:cjson",
      "c_utils:utils",
      "hilog:libhilog",
      "init:libbegetutil",
    ]
  }

  # Sandbox-level tests for unlock mount (DoSharedMountForUser, etc.)
  # Uses -Dprivate=public and function pointer defines for system call stubs
  ohos_unittest("AppSpawn_Unlock_Mount_Sandbox_Test") {
    module_out_path = "appspawn/appspawn"
    cflags = [ "-Dprivate=public" ]
    if (appspawn_unittest_coverage) {
      cflags += [ "--coverage" ]
      ldflags = [ "--coverage" ]
      cflags_cc = [ "--coverage" ]
    }
    defines = [
      "APPSPAWN_BASE_DIR=\"/data/appspawn_ut\"",
      "APPSPAWN_LABEL=\"APPSPAWN_UT\"",
      "APPSPAWN_TEST",
      "APPSPAWN_CLIENT",
      "APPSPAWN_DEBUG",
      "DEBUG_BEGETCTL_BOOT",
      "USER_TIMER_TO_CHECK",
      "OHOS_DEBUG",
    ]

    include_dirs = [
      "${appspawn_path}",
      "${appspawn_path}/common",
      "${appspawn_path}/standard",
      "${appspawn_path}/modules/modulemgr",
      "${appspawn_path}/modules/common",
      "${appspawn_path}/modules/sysevent",
      "${appspawn_innerkits_path}/client",
      "${appspawn_innerkits_path}/include",
      "${appspawn_innerkits_path}/permission",
      "${appspawn_path}/test/mock",
      "${appspawn_path}/test/unittest",
      "${appspawn_path}/util/include",
    ]
    include_dirs += appspawn_sandbox_inc

    sources = [
      "${appspawn_path}/common/appspawn_server.c",
      "${appspawn_path}/common/appspawn_trace.cpp",
      "${appspawn_path}/modules/modulemgr/appspawn_modulemgr.c",
      "${appspawn_path}/standard/appspawn_appmgr.c",
      "${appspawn_path}/standard/appspawn_fd_manager.c",
      "${appspawn_path}/standard/appspawn_kickdog.c",
      "${appspawn_path}/standard/appspawn_msgmgr.c",
      "${appspawn_path}/standard/appspawn_service.c",
      "${appspawn_path}/util/src/appspawn_utils.c",
      "${appspawn_path}/util/src/appspawndf_utils.cpp",
    ]

    # modules sources
    sources += [
      "${appspawn_path}/modules/common/appspawn_adapter.cpp",
      "${appspawn_path}/modules/common/appspawn_begetctl.c",
      "${appspawn_path}/modules/common/appspawn_cgroup.c",
      "${appspawn_path}/modules/common/appspawn_common.c",
      "${appspawn_path}/modules/common/appspawn_dfx_dump.cpp",
      "${appspawn_path}/modules/common/appspawn_namespace.c",
      "${appspawn_path}/modules/common/appspawn_silk.c",
    ]
    sources += appspawn_sandbox_src

    # client
    sources += [
      "${appspawn_innerkits_path}/client/appspawn_client.c",
      "${appspawn_innerkits_path}/client/appspawn_msg.c",
      "${appspawn_innerkits_path}/permission/appspawn_mount_permission.c",
    ]


    # test
    sources += [
      "app_spawn_unlock_mount_sandbox_test.cpp",
      "${appspawn_path}/test/unittest/app_spawn_test_helper.cpp",
    ]

    configs = [ "${appspawn_path}:appspawn_config" ]
    external_deps = [
      "ability_runtime:app_manager",
      "ability_runtime:appkit_native",
      "ability_runtime:runtime",
      "access_token:libaccesstoken_sdk",
      "access_token:libtokenid_sdk",
      "access_token:libtokensetproc_shared",
      "ace_engine:ace_forward_compatibility",
      "bundle_framework:appexecfwk_base",
      "bundle_framework:appexecfwk_core",
      "cJSON:cjson",
      "config_policy:configpolicy_util",
      "c_utils:utils",
      "eventhandler:libeventhandler",
      "ffrt:libffrt",
      "googletest:gmock_main",
      "hilog:libhilog",
      "hitrace:hitrace_meter",
      "init:libbegetutil",
      "init:seccomp",
      "ipc:ipc_core",
      "os_account:os_account_innerkits",
      "resource_management:global_resmgr",
    ]

    if (appspawn_report_event) {
      defines += [ "REPORT_EVENT" ]
      external_deps += [ "hisysevent:libhisysevent" ]
      sources += [ "${appspawn_path}/modules/sysevent/hisysevent_adapter.cpp" ]
    }

    if (asan_detector || is_asan) {
      defines += [ "ASAN_DETECTOR" ]
      sources += [ "${appspawn_path}/modules/asan/asan_detector.c" ]
    }

    if (build_selinux) {
      defines += [ "WITH_SELINUX" ]
      external_deps += [
        "selinux:libselinux",
        "selinux_adapter:libhap_restorecon",
      ]
    }

    if (target_cpu == "arm64" || target_cpu == "x86_64" ||
        target_cpu == "riscv64") {
      defines += [ "APPSPAWN_64" ]
    }
  }

  # Service-level tests for unlock mount (HandleUnlockEvent, SendUnlockMsgToPrefork, etc.)
  ohos_unittest("AppSpawn_Unlock_Mount_Service_Test") {
    module_out_path = "appspawn/appspawn"
    cflags = [ "-Dprivate=public" ]
    ldflags = [
      "-Wl,--wrap=ProcessExit",
      "-Wl,--wrap=SetParameter",
      "-Wl,--wrap=fork",
      "-Wl,--wrap=kill",
    ]
    if (appspawn_unittest_coverage) {
      cflags += [ "--coverage" ]
      ldflags += [ "--coverage" ]
      cflags_cc = [ "--coverage" ]
    }
    defines = [
      "APPSPAWN_BASE_DIR=\"/data/appspawn_ut\"",
      "APPSPAWN_LABEL=\"APPSPAWN_UT\"",
      "APPSPAWN_TEST",
      "APPSPAWN_CLIENT",
      "APPSPAWN_DEBUG",
      "DEBUG_BEGETCTL_BOOT",
      "USER_TIMER_TO_CHECK",
      "OHOS_DEBUG",
    ]

    include_dirs = [
      "${appspawn_path}",
      "${appspawn_path}/common",
      "${appspawn_path}/standard",
      "${appspawn_path}/modules/modulemgr",
      "${appspawn_path}/modules/common",
      "${appspawn_path}/modules/sysevent",
      "${appspawn_innerkits_path}/client",
      "${appspawn_innerkits_path}/include",
      "${appspawn_innerkits_path}/permission",
      "${appspawn_path}/test/mock",
      "${appspawn_path}/test/unittest",
      "${appspawn_path}/util/include",
    ]
    include_dirs += appspawn_sandbox_inc

    sources = [
      "${appspawn_path}/common/appspawn_server.c",
      "${appspawn_path}/common/appspawn_trace.cpp",
      "${appspawn_path}/modules/modulemgr/appspawn_modulemgr.c",
      "${appspawn_path}/standard/appspawn_appmgr.c",
      "${appspawn_path}/standard/appspawn_fd_manager.c",
      "${appspawn_path}/standard/appspawn_kickdog.c",
      "${appspawn_path}/standard/appspawn_msgmgr.c",
      "${appspawn_path}/standard/appspawn_service.c",
      "${appspawn_path}/util/src/appspawn_utils.c",
      "${appspawn_path}/util/src/appspawndf_utils.cpp",
    ]

    # modules sources
    sources += [
      "${appspawn_path}/modules/common/appspawn_adapter.cpp",
      "${appspawn_path}/modules/common/appspawn_begetctl.c",
      "${appspawn_path}/modules/common/appspawn_cgroup.c",
      "${appspawn_path}/modules/common/appspawn_common.c",
      "${appspawn_path}/modules/common/appspawn_dfx_dump.cpp",
      "${appspawn_path}/modules/common/appspawn_namespace.c",
      "${appspawn_path}/modules/common/appspawn_silk.c",
    ]
    sources += appspawn_sandbox_src

    # client
    sources += [
      "${appspawn_innerkits_path}/client/appspawn_client.c",
      "${appspawn_innerkits_path}/client/appspawn_msg.c",
      "${appspawn_innerkits_path}/permission/appspawn_mount_permission.c",
    ]

    # test
    sources += [
      "app_spawn_unlock_mount_service_test.cpp",
      "${appspawn_path}/test/unittest/app_spawn_test_helper.cpp",
    ]

    configs = [ "${appspawn_path}:appspawn_config" ]
    external_deps = [
      "ability_runtime:app_manager",
      "ability_runtime:appkit_native",
      "ability_runtime:runtime",
      "access_token:libaccesstoken_sdk",
      "access_token:libtokenid_sdk",
      "access_token:libtokensetproc_shared",
      "ace_engine:ace_forward_compatibility",
      "bundle_framework:appexecfwk_base",
      "bundle_framework:appexecfwk_core",
      "cJSON:cjson",
      "config_policy:configpolicy_util",
      "c_utils:utils",
      "eventhandler:libeventhandler",
      "ffrt:libffrt",
      "googletest:gmock_main",
      "hilog:libhilog",
      "hitrace:hitrace_meter",
      "init:libbegetutil",
      "init:seccomp",
      "ipc:ipc_core",
      "os_account:os_account_innerkits",
      "resource_management:global_resmgr",
    ]

    if (build_selinux) {
      defines += [ "WITH_SELINUX" ]
      external_deps += [
        "selinux:libselinux",
        "selinux_adapter:libhap_restorecon",
      ]
    }

    if (target_cpu == "arm64" || target_cpu == "x86_64" ||
        target_cpu == "riscv64") {
      defines += [ "APPSPAWN_64" ]
    }
  }

}
