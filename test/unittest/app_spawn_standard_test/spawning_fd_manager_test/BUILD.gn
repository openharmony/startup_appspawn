      "${appspawn_path}/standard/appspawn_appmgr.c",
      "${appspawn_path}/standard/appspawn_fd_manager.c",
      "${appspawn_path}/standard/appspawn_kickdog.c",
      "${appspawn_path}/standard/appspawn_msgmgr.c",
